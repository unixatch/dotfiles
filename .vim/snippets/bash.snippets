snippet func
	$1() {
		$0
	}
snippet case
	case $1 in
		$2)
			$0
		;;
	esac
snippet fora
	for (( i = 0; i < $1; i++ )) ;{
		$0
	}
snippet forin
	for $1 in "$2" ;{
		$0
	}
snippet [[
	[[ $1 ]] && {
		$0
	}
snippet ((
	(( $1 )) && {
		$0
	}
snippet if
	if $1 ;then
		$0
	fi
snippet echo
	echo "$0"
snippet printf
	printf '$0' "$1"
snippet mapfile
	mapfile -t $1 <<< "$0"
snippet wr
	while read -r line ;do
		$0
	done < <($1)
snippet =~
	[[ $1 =~ $2 ]] && {
		$0
	}
snippet echoe
	echo -e "$0"
