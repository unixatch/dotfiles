snippet /**
	/**
	 * ${0}
	 */
snippet =>
	() => {${0}}
snippet func
	function ${1}(${2}) {
		${0}
	}
snippet try
	try {
		${1}
	} catch (e) {
		${0}
	}
snippet for
	for (let i = 0; i < ${1}; i++) {
		${0}
	}
snippet forof
	for (const i of ${1}) {
		${0}
	}
snippet if
	if (${1}) {
		${0}
	}
snippet ct
	console.time("test")${0}
snippet cte
	console.timeEnd("test")${0}
snippet cl
	console.log(${0})
snippet ce
	console.error(${0})
snippet pexit
	process.exit(${0})
snippet switch
	switch (${1}) {
		case "${3}":
			${0}
			break;

		default:
			${2}
	}
snippet case
	case "${1}":
		${0}
		break;
snippet db
	debugger;${0}

